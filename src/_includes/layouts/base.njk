<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ titre }} — Soly'bat</title>
  <meta name="description" content="{{ description }}">
  {% if noindex %}<meta name="robots" content="noindex">{% endif %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="icon" href="{{ '/images/favicon.png' | url }}" type="image/png">
  <link rel="apple-touch-icon" href="{{ '/images/apple-touch-icon.png' | url }}">
  <link rel="manifest" href="{{ '/manifest.json' | url }}">
  <meta name="theme-color" content="#EDE4D3">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600&family=Inter:wght@400;600&display=swap">
  <link rel="stylesheet" href="{{ '/css/styles.css' | url }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="fr_FR">
  <meta property="og:site_name" content="Soly'bat">
  <meta property="og:title" content="{{ titre }} — Soly'bat">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/images/og-image.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ titre }} — Soly'bat">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="{{ site.url }}/images/og-image.jpg">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "GeneralContractor",
    "name": "Soly'bat",
    "url": "{{ site.url }}",
    "image": "{{ site.url }}/images/logo-solybat.png",
    "telephone": "{{ site.telephoneLien }}",
    "email": "{{ site.email }}",
    "description": "Entreprise de rénovation de biens immobiliers en vue de mise en location : diagnostic, chantier tous corps de métier, remise des clés.",
    "areaServed": {
      "@type": "AdministrativeArea",
      "name": "Vierzon et environ 50 km alentour (Cher, Centre-Val de Loire)"
    }
  }
  </script>
</head>
<body>
  <a href="#contenu-principal" class="lien-evitement">Aller au contenu</a>
  {% include "composants/bandeau-nouveaute.njk" %}
  {% include "composants/header.njk" %}
  <main id="contenu-principal">
    {{ content | safe }}
  </main>
  {% include "composants/footer.njk" %}
  <script type="module" src="{{ '/js/main.js' | url }}"></script>
</body>
</html>
