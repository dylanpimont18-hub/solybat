---
layout: layouts/base.njk
pagination:
  data: realisations
  size: 1
  alias: projet
permalink: "/realisations/{{ projet.slug }}/"
eleventyComputed:
  titre: "{{ projet.titre | replace(' — ', ', ') | safe }}"
  description: "{{ projet.resume | safe }}"
---
{% from "composants/placeholder-photo.njk" import placeholderPhoto %}
<section class="conteneur">
  <p><a href="{{ '/realisations/' | url }}">← Retour aux réalisations</a></p>
  <h1>{{ projet.titre }}</h1>

  {% if projet.photos.avant and projet.photos.apres %}
  <div class="slider-avant-apres" data-slider-avant-apres>
    <img class="slider-avant-apres__calque" src="{{ ('/images/realisations/' + projet.photos.avant) | url }}" alt="{{ projet.titre }} — avant" fetchpriority="high" decoding="async">
    <img class="slider-avant-apres__calque" data-slider-apres src="{{ ('/images/realisations/' + projet.photos.apres) | url }}" alt="{{ projet.titre }} — après" style="clip-path: inset(0 0 0 50%);" decoding="async">
    <div class="slider-avant-apres__curseur" data-slider-curseur tabindex="0" role="slider" aria-orientation="horizontal" aria-label="Comparer avant et après" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50"></div>
  </div>
  {% else %}
  {{ placeholderPhoto() }}
  {% endif %}

  <dl class="projet__meta">
    <div><dt>Surface</dt><dd>{{ projet.surface }}</dd></div>
    <div><dt>Durée</dt><dd>{{ projet.duree }}</dd></div>
    <div><dt>Corps de métier</dt><dd>{{ projet.corpsDeMetier | join(", ") }}</dd></div>
  </dl>

  <p>{{ projet.resume }}</p>
</section>
